# SSH client config on the server

# Keep connections alive
Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3

# GitHub - uses the forwarded SSH agent from your laptop
# No ForwardAgent here: we don't want to chain agent forwarding beyond the server
Host github.com
    User git
    ForwardAgent no

# GitLab - same pattern
Host gitlab.com
    User git
    ForwardAgent no
